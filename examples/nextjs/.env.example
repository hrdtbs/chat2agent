# Bot display name used for @mention detection (match your Slack / Discord app)
BOT_USER_NAME=chat2agent

# Default target when the message does not contain "devin" or "jules"
CHAT2AGENT_DEFAULT_AGENT=devin

# Max prereq prompts (Jules source/branch, etc.) before createSession
CHAT2AGENT_MAX_CLARIFICATION=5

# Optional: use Vercel Cron + Upstash instead of Next.js `after()` for agent polling
# CHAT2AGENT_USE_CRON_POLL=1
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# CRON_SECRET=long-random-string
# CHAT2AGENT_POLL_INTERVAL_MS=3000
# CHAT2AGENT_POLL_MAX_ITERATIONS=40

# --- Slack (single-workspace) — @chat-adapter/slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# --- Discord — @chat-adapter/discord
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_APPLICATION_ID=your-application-id
DISCORD_PUBLIC_KEY=your-public-key

# Optional: role IDs (comma-separated) that count as mentions
# DISCORD_MENTION_ROLE_IDS=

# --- Devin API v3 — https://docs.devin.ai/api-reference/v3/overview.md
DEVIN_API_KEY=cog_your_service_user_token
DEVIN_ORG_ID=your_org_id

# --- Jules API — https://developers.google.com/jules/api
JULES_API_KEY=your_jules_api_key

# Optional defaults so Jules can skip asking for source/branch
# JULES_DEFAULT_SOURCE=sources/1234567890
# JULES_DEFAULT_BRANCH=main

# Production: swap createMemoryState() for Redis — see README
