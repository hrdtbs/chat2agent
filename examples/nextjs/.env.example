# Bot display name used for @mention detection (match your Slack app)
BOT_USER_NAME=chat2agent

# Max prereq prompts before createSession (example uses none; hook is still available)
CHAT2AGENT_MAX_CLARIFICATION=5

# --- Slack (single-workspace) — @chat-adapter/slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# --- Devin API v3 — https://docs.devin.ai/api-reference/v3/overview.md
DEVIN_API_KEY=cog_your_service_user_token
DEVIN_ORG_ID=your_org_id

# Production: swap createMemoryState() for Redis — see README
